PUBLIC_BUCKET=public-bucket
PRIVATE_BUCKET=private-bucket
AWS_REGION=us-east-1
HOST=0.0.0.0
PORT=8080

# JSON registry manifests stored in both S3 buckets
REGISTRY_MANIFEST_KEY=.parparchik/files.json

# For MinIO / custom S3 endpoint (leave empty for real AWS)
S3_ENDPOINT=localhost:9000

# AWS credentials (or use IAM role / ~/.aws/credentials)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
